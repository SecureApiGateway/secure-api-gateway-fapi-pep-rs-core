{
  "properties": {
    "security": {
    },
    "urls": {
      "idmBaseUri": "https://&{identity.platform.fqdn}/openidm"
    },
    "vertxConfig": {
      "maxHeaderSize": 16384,
      "initialSettings": {
        "maxHeaderListSize": 16384
      }
    }
  },
  "handler": "_router",
  "heap": [
    {
      "name": "_router",
      "type": "Router",
      "config": {
        "scanInterval": "30 seconds",
        "directory": "${openig.configDirectory}/routes",
        "defaultHandler": {
          "type": "DispatchHandler",
          "config": {
            "bindings": [
              {
                "condition": "${request.method == 'GET' and request.uri.path == '/'}",
                "handler": {
                  "type": "WelcomeHandler"
                }
              },
              {
                "condition": "${request.uri.path == '/'}",
                "handler": {
                  "type": "StaticResponseHandler",
                  "config": {
                    "status": 405,
                    "reason": "Method Not Allowed"
                  }
                }
              },
              {
                "handler": {
                  "type": "StaticResponseHandler",
                  "config": {
                    "status": 404,
                    "reason": "Not Found"
                  }
                }
              }
            ]
          }
        }
      }
    },
    {
      "name": "capture",
      "type": "CaptureDecorator",
      "config": {
        "captureEntity": true
      }
    },
    {
      "name": "AuditService",
      "type": "AuditService",
      "config": {
        "eventHandlers": [
          {
            "class": "org.forgerock.audit.handlers.json.stdout.JsonStdoutAuditEventHandler",
            "config": {
              "name": "access",
              "elasticsearchCompatible": false,
              "topics": [
                "access"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "ReverseProxyHandler",
      "type": "ReverseProxyHandler",
      "capture": [
        "request",
        "response"
      ],
      "config": {
        "vertx": "${vertxConfig}"
      }
    },
    {
      "name": "ReverseProxyHandlerNoCapture",
      "type": "ReverseProxyHandler",
      "comment": "ReverseProxyHandler with no capture decorator configuration",
      "config": {
        "vertx": "${vertxConfig}"
      }
    },
    {
      "name": "JwtSession",
      "type": "JwtSession"
    },
    {
      "name" : "ForgeRockClientHandler",
      "type" : "Chain",
      "config" : {
        "filters" : [ 
          "TransactionIdOutboundFilter"
       ],
        "handler" : "ClientHandler"
      },
      "capture" : [ "response", "request" ]
    },
    {
      "name": "SystemAndEnvSecretStore-IAM",
      "type": "SystemAndEnvSecretStore",
      "config": {
        "format": "PLAIN"
      }
    },
    {
      "name": "TrustManager-OB",
      "type": "SecretsTrustManager",
      "config": {
        "certificateVerificationSecretId": "ca.ob.secret.id",
        "secretsProvider": {
          "type": "KeyStoreSecretStore",
          "config": {
            "file": "&{ig.instance.dir}&{ig.truststore.path}",
            "storeType": "PKCS12",
            "storePasswordSecretId": "ig.truststore.password",
            "secretsProvider": "SystemAndEnvSecretStore-IAM",
            "mappings": [{
              "secretId": "ca.ob.secret.id",
              "aliasesMatching": [".*"]
            }]
          }
        }
      }
    },
    {
      "name": "OBClientHandler",
      "type": "ClientHandler",
      "capture": "all",
      "config": {
        "tls": {
          "type": "ClientTlsOptions",
          "config": {
            "trustManager": "TrustManager-OB"
          }
        }
      }
    },
    {
      "name": "JwkSetService",
      "type": "CachingJwkSetService",
      "config": {
        "endpointHandler": "OBClientHandler",
        "cacheMaxSize": 500,
        "cacheTimeout": "24 hours"
      }
    },
    {
      "name": "SecretsProvider-AmJWK",
      "type": "SecretsProvider",
      "config": {
        "stores": [
          {
            "type": "JwkSetSecretStore",
            "config": {
              "jwkUrl": "https://&{identity.platform.fqdn}/am/oauth2/realms/root/realms/&{am.realm}/connect/jwk_uri"
            }
          }
        ]
      }
    }
  ],
  "monitor": true
}
